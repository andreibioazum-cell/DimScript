 -- DimScript
struct Player
    var name: string
    var hp: i32
end

func damage_player(p: Player, amount: i32)
    p.hp = p.hp - amount
    print("Player damaged")
end

func on_ui_render()
    ui.begin_window("DimScript Dashboard")
    ui.text("Hello World")
    if ui.button("Click") then
        print("Click!")
    end
    ui.end_window()
end
